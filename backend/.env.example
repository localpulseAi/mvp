# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/localpulse
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
MAGIC_LINK_EXPIRE_MINUTES=15
SESSION_EXPIRE_DAYS=30

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@localpulse.ai
EMAIL_FROM_NAME=LocalPulse AI

# Google Places
GOOGLE_PLACES_API_KEY=AIza...

# Apify (competitor scraping)
APIFY_API_TOKEN=apify_api_...

# Search (Tavily)
TAVILY_API_KEY=tvly-...

# Weather (Open-Meteo is free, no key needed)

# Sentry
SENTRY_DSN=https://...@sentry.io/...

# App
APP_ENV=development
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Cost budgets (USD cents)
MAX_COST_PER_SESSION_CENTS=300
MAX_COST_PER_OWNER_MONTH_CENTS=8000
